# ── SpotFinder Mobile — Environment Variables (example) ──────────────────────
#
# Copy this file to .env and fill in the correct values.
#
# Android Emulator:  EXPO_PUBLIC_API_URL=http://10.0.2.2:5000
# Physical Device:   EXPO_PUBLIC_API_URL=http://<your-local-ip>:5000
# iOS Simulator:     EXPO_PUBLIC_API_URL=http://localhost:5000
#
EXPO_PUBLIC_API_URL=http://10.0.2.2:5000
